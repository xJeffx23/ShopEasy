generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Catalogo_Departamento {
  idCatalogo_Departamento Int        @id(map: "PK_Catalogo_Departamento") @default(autoincrement())
  Nombre_Departamento     String     @db.NVarChar(50)
  Activo                  Boolean    @default(true, map: "DF__Catalogo___Activ__37A5467C")
  Empleados               Empleado[]
}

model Catalogo_Perfil_Usuario {
  idCatalogo_Perfil_Usuario Int        @id(map: "PK_Catalogo_Perfil_Usuario") @default(autoincrement())
  Nombre_Perfil             String     @db.NVarChar(50)
  Descripcion               String     @db.NVarChar(200)
  Activo                    Boolean    @default(true, map: "DF__Catalogo___Activ__3A81B327")
  Empleados                 Empleado[]
}

model Catalogo_Nivel_Asistencia {
  idCatalogo_Nivel_Asistencia Int        @id(map: "PK_Catalogo_Nivel_Asistencia") @default(autoincrement())
  Descripcion_Nivel           String     @db.NVarChar(100)
  Activo                      Boolean    @default(true, map: "DF__Catalogo___Activ__3D5E1FD2")
  Pacientes                   Paciente[]
}

model Catalogo_Cuidado_Especial {
  idCatalogo_Cuidado_Especial Int                         @id(map: "PK_Catalogo_Cuidado_Especial") @default(autoincrement())
  Descripcion_Cuidado         String                      @db.NVarChar(100)
  Activo                      Boolean                     @default(true, map: "DF__Catalogo___Activ__403A8C7D")
  Paciente_Cuidados           Paciente_Cuidado_Especial[]
}

model Catalogo_Paquete_Adicional {
  idCatalogo_Paquete_Adicional Int                @id(map: "PK_Catalogo_Paquete_Adicional") @default(autoincrement())
  Nombre_Paquete               String             @db.NVarChar(100)
  Descripcion                  String             @db.NVarChar(200)
  Costo_Adicional              Decimal            @default(0.00, map: "DF__Catalogo___Costo__4316F928") @db.Decimal(10, 2)
  Activo                       Boolean            @default(true, map: "DF__Catalogo___Activ__440B1D61")
  Paciente_Paquetes            Paciente_Paquete[]
}

model Catalogo_Tipo_Habitacion {
  idCatalogo_Tipo_Habitacion Int          @id(map: "PK_Catalogo_Tipo_Habitacion") @default(autoincrement())
  Nombre_Tipo                String       @db.NVarChar(100)
  Descripcion                String       @db.NVarChar(200)
  Costo_Por_Dia              Decimal      @db.Decimal(10, 2)
  Activo                     Boolean      @default(true, map: "DF__Catalogo___Activ__46E78A0C")
  Habitaciones               Habitacion[]
}

model Catalogo_Estado_Habitacion {
  idCatalogo_Estado_Habitacion Int          @id(map: "PK_Catalogo_Estado_Habitacion") @default(autoincrement())
  Descripcion_Estado           String       @db.NVarChar(50)
  Activo                       Boolean      @default(true, map: "DF__Catalogo___Activ__49C3F6B7")
  Habitaciones                 Habitacion[]
}

model Catalogo_Tipo_Estancia {
  idCatalogo_Tipo_Estancia Int           @id(map: "PK_Catalogo_Tipo_Estancia") @default(autoincrement())
  Descripcion_Estancia     String        @db.NVarChar(100)
  Hora_Inicio              String        @db.NVarChar(10)
  Hora_Fin                 String        @db.NVarChar(10)
  Activo                   Boolean       @default(true, map: "DF__Catalogo___Activ__4CA06362")
  Reservaciones            Reservacion[]
}

model Catalogo_Estado_Reservacion {
  idCatalogo_Estado_Reservacion Int           @id(map: "PK_Catalogo_Estado_Reservacion") @default(autoincrement())
  Descripcion_Estado            String        @db.NVarChar(50)
  Activo                        Boolean       @default(true, map: "DF__Catalogo___Activ__4F7CD00D")
  Reservaciones                 Reservacion[]
}

model Catalogo_Estado_Reparacion {
  idCatalogo_Estado_Reparacion Int                    @id(map: "PK_Catalogo_Estado_Reparacion") @default(autoincrement())
  Descripcion_Estado           String                 @db.NVarChar(50)
  Activo                       Boolean                @default(true, map: "DF__Catalogo___Activ__52593CB8")
  Reparaciones                 Reparacion_Pendiente[]
}

model Empleado {
  idEmpleado                           Int                        @id(map: "PK_Empleado") @default(autoincrement())
  Nombre                               String                     @db.NVarChar(100)
  Numero_Cedula                        String                     @unique(map: "UQ_Empleado_Cedula") @db.NVarChar(20)
  Fecha_Ingreso                        DateTime                   @db.Date
  Telefono                             String                     @db.NVarChar(20)
  Email                                String                     @db.NVarChar(255)
  Activo                               Boolean                    @default(true, map: "DF__Empleado__Activo__5812160E")
  Catalogo_Departamento_idDepartamento Int
  Catalogo_Perfil_Usuario_idPerfil     Int
  Departamento                         Catalogo_Departamento      @relation(fields: [Catalogo_Departamento_idDepartamento], references: [idCatalogo_Departamento], onUpdate: NoAction, map: "FK_Empleado_Departamento")
  Perfil                               Catalogo_Perfil_Usuario    @relation(fields: [Catalogo_Perfil_Usuario_idPerfil], references: [idCatalogo_Perfil_Usuario], onUpdate: NoAction, map: "FK_Empleado_Perfil")
  Limpiezas                            Limpieza_Habitacion[]
  Mantenimientos                       Mantenimiento_Habitacion[]
  Reparaciones                         Reparacion_Pendiente[]
  Reportes                             Reporte_Pacientes[]
  Reservaciones                        Reservacion[]
  Usuario                              Usuario[]

  @@index([Catalogo_Departamento_idDepartamento], map: "IX_Empleado_Departamento")
  @@index([Catalogo_Perfil_Usuario_idPerfil], map: "IX_Empleado_Perfil")
}

model Usuario {
  idUsuario           Int      @id(map: "PK_Usuario") @default(autoincrement())
  Nombre_usuario      String   @unique(map: "UQ_Usuario_NombreUsuario") @db.NVarChar(50)
  Contrasena          String   @db.NVarChar(255)
  Email               String   @unique(map: "UQ_Usuario_Email") @db.NVarChar(255)
  Activo              Boolean  @default(true, map: "DF__Usuario__Activo__5EBF139D")
  Fecha_Creacion      DateTime @default(now(), map: "DF__Usuario__Fecha_C__5FB337D6")
  Cambio_Contrasena   Boolean  @default(true, map: "DF__Usuario__Cambio___60A75C0F")
  Empleado_idEmpleado Int
  Empleado            Empleado @relation(fields: [Empleado_idEmpleado], references: [idEmpleado], onUpdate: NoAction, map: "FK_Usuario_Empleado")

  @@index([Empleado_idEmpleado], map: "IX_Usuario_Empleado")
}

model Paciente {
  idPaciente                        Int                         @id(map: "PK_Paciente") @default(autoincrement())
  Nombre                            String                      @db.NVarChar(100)
  Numero_Cedula                     String                      @unique(map: "UQ_Paciente_Cedula") @db.NVarChar(20)
  Fecha_Nacimiento                  DateTime                    @db.Date
  Fecha_Ingreso                     DateTime                    @db.Date
  Telefono_Contacto_Emergencia      String                      @db.NVarChar(20)
  Nombre_Contacto_Emergencia        String                      @db.NVarChar(100)
  Activo                            Boolean                     @default(true, map: "DF__Paciente__Activo__656C112C")
  Catalogo_Nivel_Asistencia_idNivel Int
  Nivel_Asistencia                  Catalogo_Nivel_Asistencia   @relation(fields: [Catalogo_Nivel_Asistencia_idNivel], references: [idCatalogo_Nivel_Asistencia], onUpdate: NoAction, map: "FK_Paciente_Nivel_Asistencia")
  Cuidados                          Paciente_Cuidado_Especial[]
  Medicamentos                      Paciente_Medicamento[]
  Paquetes                          Paciente_Paquete[]
  Reservaciones                     Reservacion[]
  Usuario_Paciente                  Usuario_Paciente[]

  @@index([Catalogo_Nivel_Asistencia_idNivel], map: "IX_Paciente_Nivel")
}

model Usuario_Paciente {
  idUsuario_Paciente  Int      @id(map: "PK_Usuario_Paciente") @default(autoincrement())
  Nombre_usuario      String   @unique(map: "UQ_UsuarioPaciente_Nombre") @db.NVarChar(50)
  Contrasena          String   @db.NVarChar(255)
  Email               String   @unique(map: "UQ_UsuarioPaciente_Email") @db.NVarChar(255)
  Activo              Boolean  @default(true, map: "DF__Usuario_P__Activ__6B24EA82")
  Fecha_Creacion      DateTime @default(now(), map: "DF__Usuario_P__Fecha__6C190EBB")
  Cambio_Contrasena   Boolean  @default(true, map: "DF__Usuario_P__Cambi__6D0D32F4")
  Paciente_idPaciente Int
  Paciente            Paciente @relation(fields: [Paciente_idPaciente], references: [idPaciente], onUpdate: NoAction, map: "FK_UsuarioPaciente_Paciente")

  @@index([Paciente_idPaciente], map: "IX_UsuarioPaciente_Paciente")
}

model Paciente_Medicamento {
  idPaciente_Medicamento Int      @id(map: "PK_Paciente_Medicamento") @default(autoincrement())
  Nombre_Medicamento     String   @db.NVarChar(100)
  Dosis                  String   @db.NVarChar(100)
  Frecuencia             String   @db.NVarChar(100)
  Indicaciones           String   @db.NVarChar(300)
  Activo                 Boolean  @default(true, map: "DF__Paciente___Activ__70DDC3D8")
  Paciente_idPaciente    Int
  Paciente               Paciente @relation(fields: [Paciente_idPaciente], references: [idPaciente], onUpdate: NoAction, map: "FK_Medicamento_Paciente")

  @@index([Paciente_idPaciente], map: "IX_Medicamento_Paciente")
}

model Paciente_Cuidado_Especial {
  idPaciente_Cuidado                  Int                       @id(map: "PK_Paciente_Cuidado_Especial") @default(autoincrement())
  Detalle                             String                    @db.NVarChar(300)
  Paciente_idPaciente                 Int
  Catalogo_Cuidado_Especial_idCuidado Int
  Tipo_Cuidado                        Catalogo_Cuidado_Especial @relation(fields: [Catalogo_Cuidado_Especial_idCuidado], references: [idCatalogo_Cuidado_Especial], onUpdate: NoAction, map: "FK_Cuidado_Catalogo")
  Paciente                            Paciente                  @relation(fields: [Paciente_idPaciente], references: [idPaciente], onUpdate: NoAction, map: "FK_Cuidado_Paciente")

  @@index([Catalogo_Cuidado_Especial_idCuidado], map: "IX_Cuidado_Catalogo")
  @@index([Paciente_idPaciente], map: "IX_Cuidado_Paciente")
}

model Paciente_Paquete {
  idPaciente_Paquete         Int                        @id(map: "PK_Paciente_Paquete") @default(autoincrement())
  Fecha_Asignacion           DateTime                   @default(now(), map: "DF__Paciente___Fecha__787EE5A0") @db.Date
  Activo                     Boolean                    @default(true, map: "DF__Paciente___Activ__797309D9")
  Paciente_idPaciente        Int
  Catalogo_Paquete_idPaquete Int
  Paquete                    Catalogo_Paquete_Adicional @relation(fields: [Catalogo_Paquete_idPaquete], references: [idCatalogo_Paquete_Adicional], onUpdate: NoAction, map: "FK_Paquete_Catalogo")
  Paciente                   Paciente                   @relation(fields: [Paciente_idPaciente], references: [idPaciente], onUpdate: NoAction, map: "FK_Paquete_Paciente")

  @@index([Catalogo_Paquete_idPaquete], map: "IX_Paquete_Catalogo")
  @@index([Paciente_idPaciente], map: "IX_Paquete_Paciente")
}

model Habitacion {
  idHabitacion                        Int                        @id(map: "PK_Habitacion") @default(autoincrement())
  Numero_Habitacion                   String                     @unique(map: "UQ_Habitacion_Numero") @db.NVarChar(10)
  Piso                                Int
  Capacidad                           Int                        @default(1, map: "DF__Habitacio__Capac__7F2BE32F")
  Observaciones                       String?                    @db.NVarChar(300)
  Catalogo_Tipo_Habitacion_idTipo     Int
  Catalogo_Estado_Habitacion_idEstado Int
  Estado                              Catalogo_Estado_Habitacion @relation(fields: [Catalogo_Estado_Habitacion_idEstado], references: [idCatalogo_Estado_Habitacion], onUpdate: NoAction, map: "FK_Habitacion_Estado")
  Tipo                                Catalogo_Tipo_Habitacion   @relation(fields: [Catalogo_Tipo_Habitacion_idTipo], references: [idCatalogo_Tipo_Habitacion], onUpdate: NoAction, map: "FK_Habitacion_Tipo")
  Limpiezas                           Limpieza_Habitacion[]
  Mantenimientos                      Mantenimiento_Habitacion[]
  Reparaciones                        Reparacion_Pendiente[]
  Reservaciones                       Reservacion[]

  @@index([Catalogo_Estado_Habitacion_idEstado], map: "IX_Habitacion_Estado")
  @@index([Catalogo_Tipo_Habitacion_idTipo], map: "IX_Habitacion_Tipo")
}

model Reservacion {
  idReservacion                        Int                         @id(map: "PK_Reservacion") @default(autoincrement())
  Fecha_Inicio                         DateTime                    @db.Date
  Fecha_Fin                            DateTime?                   @db.Date
  Indefinido                           Boolean                     @default(false, map: "DF__Reservaci__Indef__03F0984C")
  Observaciones                        String?                     @db.NVarChar(300)
  Fecha_Registro                       DateTime                    @default(now(), map: "DF__Reservaci__Fecha__04E4BC85")
  Activo                               Boolean                     @default(true, map: "DF__Reservaci__Activ__05D8E0BE")
  Paciente_idPaciente                  Int
  Habitacion_idHabitacion              Int
  Catalogo_Tipo_Estancia_idEstancia    Int
  Catalogo_Estado_Reservacion_idEstado Int
  Empleado_idEmpleado_Registra         Int
  Empleado                             Empleado                    @relation(fields: [Empleado_idEmpleado_Registra], references: [idEmpleado], onUpdate: NoAction, map: "FK_Reservacion_Empleado")
  Estado                               Catalogo_Estado_Reservacion @relation(fields: [Catalogo_Estado_Reservacion_idEstado], references: [idCatalogo_Estado_Reservacion], onUpdate: NoAction, map: "FK_Reservacion_Estado")
  Habitacion                           Habitacion                  @relation(fields: [Habitacion_idHabitacion], references: [idHabitacion], onUpdate: NoAction, map: "FK_Reservacion_Habitacion")
  Paciente                             Paciente                    @relation(fields: [Paciente_idPaciente], references: [idPaciente], onUpdate: NoAction, map: "FK_Reservacion_Paciente")
  Tipo_Estancia                        Catalogo_Tipo_Estancia      @relation(fields: [Catalogo_Tipo_Estancia_idEstancia], references: [idCatalogo_Tipo_Estancia], onUpdate: NoAction, map: "FK_Reservacion_Tipo_Estancia")

  @@index([Empleado_idEmpleado_Registra], map: "IX_Reservacion_Empleado")
  @@index([Catalogo_Estado_Reservacion_idEstado], map: "IX_Reservacion_Estado")
  @@index([Catalogo_Tipo_Estancia_idEstancia], map: "IX_Reservacion_Estancia")
  @@index([Habitacion_idHabitacion], map: "IX_Reservacion_Habitacion")
  @@index([Paciente_idPaciente], map: "IX_Reservacion_Paciente")
}

model Limpieza_Habitacion {
  idLimpieza_Habitacion   Int        @id(map: "PK_Limpieza_Habitacion") @default(autoincrement())
  Fecha_Limpieza          DateTime   @db.Date
  Observaciones           String?    @db.NVarChar(300)
  Habitacion_idHabitacion Int
  Empleado_idEmpleado     Int
  Empleado                Empleado   @relation(fields: [Empleado_idEmpleado], references: [idEmpleado], onUpdate: NoAction, map: "FK_Limpieza_Empleado")
  Habitacion              Habitacion @relation(fields: [Habitacion_idHabitacion], references: [idHabitacion], onUpdate: NoAction, map: "FK_Limpieza_Habitacion")

  @@index([Empleado_idEmpleado], map: "IX_Limpieza_Empleado")
  @@index([Habitacion_idHabitacion], map: "IX_Limpieza_Habitacion")
}

model Mantenimiento_Habitacion {
  idMantenimiento_Habitacion Int        @id(map: "PK_Mantenimiento_Habitacion") @default(autoincrement())
  Fecha_Mantenimiento        DateTime   @db.Date
  Descripcion_Reparacion     String     @db.NVarChar(500)
  Actualizacion_Mobiliario   String?    @db.NVarChar(500)
  Completado                 Boolean    @default(false, map: "DF__Mantenimi__Compl__114A936A")
  Habitacion_idHabitacion    Int
  Empleado_idEmpleado        Int
  Empleado                   Empleado   @relation(fields: [Empleado_idEmpleado], references: [idEmpleado], onUpdate: NoAction, map: "FK_Mantenimiento_Empleado")
  Habitacion                 Habitacion @relation(fields: [Habitacion_idHabitacion], references: [idHabitacion], onUpdate: NoAction, map: "FK_Mantenimiento_Habitacion")

  @@index([Empleado_idEmpleado], map: "IX_Mantenimiento_Empleado")
  @@index([Habitacion_idHabitacion], map: "IX_Mantenimiento_Habitacion")
}

model Reparacion_Pendiente {
  idReparacion_Pendiente              Int                        @id(map: "PK_Reparacion_Pendiente") @default(autoincrement())
  Descripcion                         String                     @db.NVarChar(500)
  Fecha_Reporte                       DateTime                   @default(now(), map: "DF__Reparacio__Fecha__160F4887") @db.Date
  Fecha_Resolucion                    DateTime?                  @db.Date
  Prioridad                           String                     @default("N'Media'", map: "DF__Reparacio__Prior__17036CC0") @db.NVarChar(10)
  Habitacion_idHabitacion             Int
  Empleado_idEmpleado_Reporta         Int
  Catalogo_Estado_Reparacion_idEstado Int
  Empleado                            Empleado                   @relation(fields: [Empleado_idEmpleado_Reporta], references: [idEmpleado], onUpdate: NoAction, map: "FK_Reparacion_Empleado")
  Estado                              Catalogo_Estado_Reparacion @relation(fields: [Catalogo_Estado_Reparacion_idEstado], references: [idCatalogo_Estado_Reparacion], onUpdate: NoAction, map: "FK_Reparacion_Estado")
  Habitacion                          Habitacion                 @relation(fields: [Habitacion_idHabitacion], references: [idHabitacion], onUpdate: NoAction, map: "FK_Reparacion_Habitacion")

  @@index([Empleado_idEmpleado_Reporta], map: "IX_Reparacion_Empleado")
  @@index([Catalogo_Estado_Reparacion_idEstado], map: "IX_Reparacion_Estado")
  @@index([Habitacion_idHabitacion], map: "IX_Reparacion_Habitacion")
}

model Reporte_Pacientes {
  idReporte               Int      @id(map: "PK_Reporte_Pacientes") @default(autoincrement())
  Fecha_Reporte           DateTime @default(now(), map: "DF__Reporte_P__Fecha__1DB06A4F")
  Total_Registrados       Int
  Total_Alojados          Int
  Total_Por_Dia           Int
  Habitaciones_Reservadas Int
  Habitaciones_Totales    Int
  Generado_Por            Int
  Empleado                Empleado @relation(fields: [Generado_Por], references: [idEmpleado], onUpdate: NoAction, map: "FK_Reporte_Empleado")
}

model Provincia {
  idProvincia      Int    @id(map: "PK_Provincia") @default(autoincrement())
  Nombre_Provincia String @db.NVarChar(45)
}
